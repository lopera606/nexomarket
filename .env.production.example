# ============================================================
# NexoMarket - Variables de Entorno (PRODUCCIÓN)
# ============================================================
# IMPORTANTE: Configurar TODAS estas variables en el servidor
# NO subir este archivo con valores reales a git

# Base de datos PostgreSQL (usa connection pooling en producción)
DATABASE_URL="postgresql://user:STRONG_PASSWORD@db-host:5432/nexomarket?connection_limit=20&pool_timeout=20"

# NextAuth - URL pública del dominio
NEXTAUTH_URL="https://www.nexomarket.com"
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_-base64_48"

# URL pública de la app
NEXT_PUBLIC_APP_URL="https://www.nexomarket.com"

# Stripe - USAR CLAVES LIVE EN PRODUCCIÓN
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Shippo - USAR CLAVE LIVE EN PRODUCCIÓN
SHIPPO_API_KEY="shippo_live_..."

# Cloudflare R2 (almacenamiento de imágenes)
CLOUDFLARE_R2_ACCESS_KEY="your_r2_access_key"
CLOUDFLARE_R2_SECRET_KEY="your_r2_secret_key"
CLOUDFLARE_R2_BUCKET="nexomarket-images"
CLOUDFLARE_R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"

# Open Exchange Rates (tipos de cambio en tiempo real)
OPEN_EXCHANGE_RATES_APP_ID="your_app_id"

# Modo mantenimiento
MAINTENANCE_MODE=false
MAINTENANCE_ALLOWED_IPS="TU_IP_PUBLICA"
GOD_MODE_SECRET="GENERATE_WITH_openssl_rand_-hex_24"

# Node environment
NODE_ENV=production
