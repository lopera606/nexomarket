// ============================================================
// MARKETPLACE - Esquema de Base de Datos (Prisma + PostgreSQL)
// ============================================================
// Uso: npx prisma migrate dev --name init
// Docs: https://www.prisma.io/docs
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum StoreStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  DELETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PENDING
  ACCEPTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum ShipmentStatus {
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  RETURNED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum NotificationType {
  ORDER_UPDATE
  MESSAGE
  PROMO
  SYSTEM
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// --- Incident / Dispute Module ---

enum IncidentType {
  NON_DELIVERY       // Producto no entregado
  LATE_DELIVERY      // Entrega muy retrasada
  DAMAGED_ITEM       // Producto dañado
  WRONG_ITEM         // Producto incorrecto
  DEFECTIVE_ITEM     // Producto defectuoso
  REFUND_REQUEST     // Solicitud de reembolso
  SELLER_NO_RESPONSE // Vendedor no responde
  OTHER              // Otro motivo
}

enum IncidentStatus {
  OPEN               // Recién creada por cliente
  AWAITING_SELLER    // Esperando respuesta del vendedor
  AWAITING_CUSTOMER  // Vendedor respondió, esperando cliente
  IN_MEDIATION       // Plataforma interviene como mediador
  ESCALATED          // Escalada a admin
  RESOLVED           // Resuelta satisfactoriamente
  CLOSED             // Cerrada (sin resolución o expirada)
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PenaltyType {
  WARNING                  // Advertencia sin consecuencias
  VISIBILITY_REDUCTION     // Reducción de visibilidad en búsquedas
  COMMISSION_INCREASE      // Aumento temporal de comisión
  FEATURE_RESTRICTION      // Restricción de funciones (cupones, destacados)
  TEMPORARY_SUSPENSION     // Suspensión temporal de la tienda
  PERMANENT_SUSPENSION     // Suspensión definitiva
}

enum PenaltyStatus {
  ACTIVE
  EXPIRED
  APPEALED
  REVOKED
}

// ============================================================
// USUARIOS Y AUTENTICACION
// ============================================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  phone             String?
  avatarUrl         String?   @map("avatar_url")
  role              UserRole  @default(CUSTOMER)
  locale            String    @default("es")
  preferredCurrency String    @default("MXN") @map("preferred_currency")
  isVerified        Boolean   @default(false) @map("is_verified")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relaciones
  addresses        Address[]
  store            Store?
  orders           Order[]
  reviews          Review[]
  wishlist         Wishlist[]
  notifications    Notification[]
  cart             Cart?
  sentMessages     Message[]          @relation("sender")
  incidents        Incident[]         @relation("incidentCustomer")
  incidentMessages IncidentMessage[]  @relation("incidentMessageSender")
  conversations    Conversation[]     @relation("conversationCustomer")
  chatMessages     ChatMessage[]      @relation("chatMessageSender")

  @@map("users")
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  label       String   @default("Casa")
  fullName    String   @map("full_name")
  streetLine1 String   @map("street_line1")
  streetLine2 String?  @map("street_line2")
  city        String
  state       String
  postalCode  String   @map("postal_code")
  country     String   @default("MX")
  phone       String?
  isDefault   Boolean  @default(false) @map("is_default")
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("shippingAddress")
  billingOrders  Order[] @relation("billingAddress")

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// TIENDA
// ============================================================

model Store {
  id                   String      @id @default(uuid()) @db.Uuid
  ownerId              String      @unique @map("owner_id") @db.Uuid
  name                 String
  slug                 String      @unique
  description          String?     @db.Text
  logoUrl              String?     @map("logo_url")
  bannerUrl            String?     @map("banner_url")
  email                String?
  phone                String?
  status               StoreStatus @default(PENDING)
  planTier             PlanTier    @default(FREE) @map("plan_tier")
  commissionRate       Decimal     @default(6.00) @map("commission_rate") @db.Decimal(5, 2)
  maxProducts          Int         @default(50) @map("max_products")
  stripeAccountId      String?     @unique @map("stripe_account_id")
  stripeOnboarded      Boolean     @default(false) @map("stripe_onboarded")
  stripeSubscriptionId String?     @unique @map("stripe_subscription_id")
  apiKey               String?     @unique @map("api_key")
  returnPolicy         Json?       @map("return_policy")
  socialLinks          Json?       @map("social_links")       // { instagram, twitter, facebook, tiktok, youtube, linkedin, pinterest, website }
  brandColors          Json?       @map("brand_colors")       // { primary, secondary, accent, background }
  businessHours        Json?       @map("business_hours")     // { mon: {open, close}, tue: ... }
  shippingInfo         Json?       @map("shipping_info")      // { freeShippingMin, avgDeliveryDays, shippingZones, returnDays }
  storeFeatures        Json?       @map("store_features")     // Array of feature strings shown on store page
  seoMetadata          Json?       @map("seo_metadata")       // { metaTitle, metaDescription, keywords }
  paymentMethods       Json?       @map("payment_methods")    // Array of accepted payment methods
  announcement         String?     @db.Text                   // Banner announcement text
  announcementActive   Boolean     @default(false) @map("announcement_active")
  location             Json?                                  // { address, city, state, country, postalCode, lat, lng }
  languages            String[]    @default(["es"])            // Idiomas que habla la tienda
  certifications       Json?                                  // Sellos de confianza, certificaciones
  faqContent           Json?       @map("faq_content")        // Array of { question, answer }
  avgRating            Decimal     @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews         Int         @default(0) @map("total_reviews")
  approvedAt           DateTime?   @map("approved_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  // Relaciones
  owner        User               @relation(fields: [ownerId], references: [id])
  products     Product[]
  subOrders    SubOrder[]
  payouts      SellerPayout[]
  coupons      Coupon[]
  messages     Message[]
  subscription StoreSubscription?
  incidents     Incident[]
  penalties     StorePenalty[]
  healthScore   StoreHealthScore?
  conversations Conversation[]     @relation("conversationStore")

  @@index([status])
  @@index([slug])
  @@map("stores")
}

// ============================================================
// CATALOGO DE PRODUCTOS
// ============================================================

model Category {
  id              String  @id @default(uuid()) @db.Uuid
  parentId        String? @map("parent_id") @db.Uuid
  name            String
  slug            String  @unique
  description     String?
  imageUrl        String? @map("image_url")
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")
  attributeSchema Json?   @map("attribute_schema")

  // Relaciones (arbol de categorias)
  parent          Category?        @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[]       @relation("CategoryTree")
  products        Product[]
  commissionTiers CommissionTier[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id             String        @id @default(uuid()) @db.Uuid
  storeId        String        @map("store_id") @db.Uuid
  categoryId     String?       @map("category_id") @db.Uuid
  name           String
  slug           String        @unique
  description    String?       @db.Text
  basePrice      Decimal       @map("base_price") @db.Decimal(12, 2)
  compareAtPrice Decimal?      @map("compare_at_price") @db.Decimal(12, 2)
  status         ProductStatus @default(DRAFT)
  sku            String?
  isFeatured     Boolean       @default(false) @map("is_featured")
  attributes     Json?
  sellingUnit    String        @default("unidad") @map("selling_unit") // unidad, metro, kg, litro, m2, pack
  minQuantity    Decimal       @default(1) @map("min_quantity") @db.Decimal(10, 3)
  quantityStep   Decimal       @default(1) @map("quantity_step") @db.Decimal(10, 3) // e.g. 0.5 for half-meter increments
  variantTypes   Json?         @map("variant_types") // [{name: "Talla", key: "talla", values: ["S","M","L"]}, {name: "Color", key: "color", values: [...]}]
  seoMetadata    Json?         @map("seo_metadata")
  avgRating      Decimal       @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews   Int           @default(0) @map("total_reviews")
  totalSold      Int           @default(0) @map("total_sold")
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relaciones
  store      Store            @relation(fields: [storeId], references: [id])
  category   Category?        @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  reviews    Review[]
  wishlist   Wishlist[]
  orderItems OrderItem[]

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([basePrice])
  @@map("products")
}

model ProductVariant {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  name              String
  sku               String   @unique
  price             Decimal  @db.Decimal(12, 2)
  compareAtPrice    Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  stockQuantity     Int      @default(0) @map("stock_quantity")
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")
  weightKg          Decimal? @map("weight_kg") @db.Decimal(8, 3)
  widthCm           Decimal? @map("width_cm") @db.Decimal(8, 2)
  heightCm          Decimal? @map("height_cm") @db.Decimal(8, 2)
  lengthCm          Decimal? @map("length_cm") @db.Decimal(8, 2)
  options           Json?
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relaciones
  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  // Relaciones
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@map("product_images")
}

// ============================================================
// CARRITO DE COMPRAS
// ============================================================

model Cart {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @unique @map("user_id") @db.Uuid
  sessionId String?   @map("session_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relaciones
  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  quantity  Int      @default(1)
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  // Relaciones
  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ============================================================
// PEDIDOS
// ============================================================

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  orderNumber       String      @unique @map("order_number")
  customerId        String      @map("customer_id") @db.Uuid
  shippingAddressId String?     @map("shipping_address_id") @db.Uuid
  billingAddressId  String?     @map("billing_address_id") @db.Uuid
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(12, 2)
  shippingTotal     Decimal     @default(0) @map("shipping_total") @db.Decimal(12, 2)
  taxTotal          Decimal     @default(0) @map("tax_total") @db.Decimal(12, 2)
  discountTotal     Decimal     @default(0) @map("discount_total") @db.Decimal(12, 2)
  grandTotal        Decimal     @map("grand_total") @db.Decimal(12, 2)
  currency          String      @default("MXN")
  couponCode        String?     @map("coupon_code")
  customerNotes     String?     @map("customer_notes") @db.Text
  placedAt          DateTime?   @map("placed_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relaciones
  customer        User        @relation(fields: [customerId], references: [id])
  shippingAddress Address?    @relation("shippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?    @relation("billingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  subOrders       SubOrder[]
  payments        Payment[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  subOrderId  String? @map("sub_order_id") @db.Uuid
  variantId   String  @map("variant_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName String  @map("product_name")
  variantName String? @map("variant_name")
  sku         String?
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)
  imageUrl    String? @map("image_url")

  // Relaciones
  order    Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subOrder SubOrder?      @relation(fields: [subOrderId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])
  review   Review?

  @@index([orderId])
  @@index([subOrderId])
  @@map("order_items")
}

model SubOrder {
  id                 String         @id @default(uuid()) @db.Uuid
  orderId            String         @map("order_id") @db.Uuid
  storeId            String         @map("store_id") @db.Uuid
  subOrderNumber     String         @unique @map("sub_order_number")
  status             SubOrderStatus @default(PENDING)
  subtotal           Decimal        @db.Decimal(12, 2)
  shippingCost       Decimal        @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  platformCommission Decimal        @map("platform_commission") @db.Decimal(12, 2)
  sellerPayout       Decimal        @map("seller_payout") @db.Decimal(12, 2)
  sellerNotes        String?        @map("seller_notes") @db.Text
  acceptedAt         DateTime?      @map("accepted_at")
  shippedAt          DateTime?      @map("shipped_at")
  deliveredAt        DateTime?      @map("delivered_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relaciones
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store    Store         @relation(fields: [storeId], references: [id])
  items    OrderItem[]
  shipment Shipment?
  payout   SellerPayout?

  @@index([orderId])
  @@index([storeId])
  @@index([status])
  @@map("sub_orders")
}

// ============================================================
// PAGOS (Stripe Connect)
// ============================================================

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  orderId               String        @map("order_id") @db.Uuid
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?       @map("stripe_charge_id")
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("MXN")
  paymentMethodType     String?       @map("payment_method_type")
  lastFour              String?       @map("last_four")
  cardBrand             String?       @map("card_brand")
  metadata              Json?
  paidAt                DateTime?     @map("paid_at")
  createdAt             DateTime      @default(now()) @map("created_at")

  // Relaciones
  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

model SellerPayout {
  id                 String       @id @default(uuid()) @db.Uuid
  storeId            String       @map("store_id") @db.Uuid
  subOrderId         String       @unique @map("sub_order_id") @db.Uuid
  stripeTransferId   String?      @unique @map("stripe_transfer_id")
  amount             Decimal      @db.Decimal(12, 2)
  commissionDeducted Decimal      @map("commission_deducted") @db.Decimal(12, 2)
  currency           String       @default("MXN")
  status             PayoutStatus @default(PENDING)
  paidAt             DateTime?    @map("paid_at")
  createdAt          DateTime     @default(now()) @map("created_at")

  // Relaciones
  store    Store    @relation(fields: [storeId], references: [id])
  subOrder SubOrder @relation(fields: [subOrderId], references: [id])

  @@index([storeId])
  @@index([status])
  @@map("seller_payouts")
}

// ============================================================
// ENVIOS (Shippo / EasyPost)
// ============================================================

model Shipment {
  id                String         @id @default(uuid()) @db.Uuid
  subOrderId        String         @unique @map("sub_order_id") @db.Uuid
  shippoShipmentId  String?        @map("shippo_shipment_id")
  carrier           String?
  serviceLevel      String?        @map("service_level")
  trackingNumber    String?        @map("tracking_number")
  trackingUrl       String?        @map("tracking_url")
  labelUrl          String?        @map("label_url")
  shippingCost      Decimal?       @map("shipping_cost") @db.Decimal(12, 2)
  weightKg          Decimal?       @map("weight_kg") @db.Decimal(8, 3)
  packageDimensions String?        @map("package_dimensions")
  status            ShipmentStatus @default(LABEL_CREATED)
  shippedAt         DateTime?      @map("shipped_at")
  estimatedDelivery DateTime?      @map("estimated_delivery")
  deliveredAt       DateTime?      @map("delivered_at")
  createdAt         DateTime       @default(now()) @map("created_at")

  // Relaciones
  subOrder SubOrder        @relation(fields: [subOrderId], references: [id])
  events   ShipmentEvent[]

  @@index([trackingNumber])
  @@map("shipments")
}

model ShipmentEvent {
  id          String   @id @default(uuid()) @db.Uuid
  shipmentId  String   @map("shipment_id") @db.Uuid
  status      String
  description String?
  location    String?
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_events")
}

// ============================================================
// RESENAS, MENSAJES, FAVORITOS
// ============================================================

model Review {
  id                 String       @id @default(uuid()) @db.Uuid
  productId          String       @map("product_id") @db.Uuid
  customerId         String       @map("customer_id") @db.Uuid
  orderItemId        String?      @unique @map("order_item_id") @db.Uuid
  rating             Int
  title              String?
  body               String?      @db.Text
  isVerifiedPurchase Boolean      @default(false) @map("is_verified_purchase")
  status             ReviewStatus @default(PENDING)
  createdAt          DateTime     @default(now()) @map("created_at")

  // Relaciones
  product   Product    @relation(fields: [productId], references: [id])
  customer  User       @relation(fields: [customerId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([productId])
  @@index([customerId])
  @@map("reviews")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  body           String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relaciones
  sender User  @relation("sender", fields: [senderId], references: [id])
  store  Store @relation(fields: [storeId], references: [id])

  @@index([conversationId])
  @@index([storeId])
  @@map("messages")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  // Relaciones
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Coupon {
  id             String     @id @default(uuid()) @db.Uuid
  storeId        String?    @map("store_id") @db.Uuid
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(12, 2)
  minOrderAmount Decimal?   @map("min_order_amount") @db.Decimal(12, 2)
  maxUses        Int?       @map("max_uses")
  usedCount      Int        @default(0) @map("used_count")
  validFrom      DateTime   @map("valid_from")
  validUntil     DateTime   @map("valid_until")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")

  // Relaciones
  store Store? @relation(fields: [storeId], references: [id])

  @@index([code])
  @@index([storeId])
  @@map("coupons")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String?          @db.Text
  actionUrl String?          @map("action_url")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// PLANES DE SUSCRIPCION (Monetizacion)
// ============================================================

model SubscriptionPlan {
  id                String   @id @default(uuid()) @db.Uuid
  tier              PlanTier @unique
  name              String
  monthlyPriceCents Int      @default(0) @map("monthly_price_cents")
  commissionRate    Decimal  @map("commission_rate") @db.Decimal(5, 2)
  maxProducts       Int      @map("max_products")
  features          Json
  stripePriceId     String?  @map("stripe_price_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relaciones
  subscriptions StoreSubscription[]

  @@map("subscription_plans")
}

model StoreSubscription {
  id                   String             @id @default(uuid()) @db.Uuid
  storeId              String             @unique @map("store_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  // Relaciones
  store Store            @relation(fields: [storeId], references: [id])
  plan  SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([status])
  @@map("store_subscriptions")
}

// ============================================================
// INTERNACIONALIZACION (Multi-moneda y Tasas)
// ============================================================

model ExchangeRate {
  id             String   @id @default(uuid()) @db.Uuid
  baseCurrency   String   @map("base_currency")
  targetCurrency String   @map("target_currency")
  rate           Decimal  @db.Decimal(14, 6)
  source         String   @default("stripe")
  fetchedAt      DateTime @map("fetched_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([baseCurrency, targetCurrency])
  @@index([baseCurrency, targetCurrency])
  @@map("exchange_rates")
}

model SupportedCountry {
  id           String  @id @default(uuid()) @db.Uuid
  countryCode  String  @unique @map("country_code")
  name         String
  currency     String
  locale       String  @default("es")
  taxServiceId String? @map("tax_service_id")
  shippingZone String? @map("shipping_zone")
  isActive     Boolean @default(true) @map("is_active")

  @@map("supported_countries")
}

// ============================================================
// CONVERSACIONES DIRECTAS (Chat Cliente-Tienda)
// ============================================================

model Conversation {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  storeId       String   @map("store_id") @db.Uuid
  subOrderId    String?  @map("sub_order_id") @db.Uuid
  subject       String?
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  isClosed      Boolean  @default(false) @map("is_closed")
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relaciones
  customer  User              @relation("conversationCustomer", fields: [customerId], references: [id])
  store     Store             @relation("conversationStore", fields: [storeId], references: [id])
  messages  ChatMessage[]

  @@unique([customerId, storeId, subOrderId])
  @@index([customerId])
  @@index([storeId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  senderRole     UserRole @map("sender_role")
  body           String   @db.Text
  attachments    Json?
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relaciones
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("chatMessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("chat_messages")
}

// ============================================================
// COMISIONES Y CONFIGURACIÓN DE PLATAFORMA
// ============================================================

model CommissionTier {
  id               String   @id @default(uuid()) @db.Uuid
  categoryId       String?  @map("category_id") @db.Uuid
  name             String
  description      String?
  baseRate         Decimal  @map("base_rate") @db.Decimal(5, 2) // % base
  minRate          Decimal  @map("min_rate") @db.Decimal(5, 2)  // % mínimo posible
  maxRate          Decimal  @map("max_rate") @db.Decimal(5, 2)  // % máximo posible
  volumeDiscount   Decimal  @default(0) @map("volume_discount") @db.Decimal(5, 2) // Descuento por volumen
  volumeThreshold  Int      @default(0) @map("volume_threshold") // Ventas/mes para descuento
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relaciones
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("commission_tiers")
}

model CommissionLog {
  id               String   @id @default(uuid()) @db.Uuid
  subOrderId       String   @map("sub_order_id") @db.Uuid
  storeId          String   @map("store_id") @db.Uuid
  orderTotal       Decimal  @map("order_total") @db.Decimal(12, 2)
  commissionRate   Decimal  @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(12, 2)
  sellerAmount     Decimal  @map("seller_amount") @db.Decimal(12, 2)
  tierName         String?  @map("tier_name")
  status           String   @default("PENDING") // PENDING, COLLECTED, REFUNDED
  collectedAt      DateTime? @map("collected_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([subOrderId])
  @@index([createdAt])
  @@map("commission_logs")
}

model PlatformSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  key                   String   @unique
  value                 String   @db.Text
  description           String?
  updatedBy             String?  @map("updated_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ============================================================
// INCIDENCIAS Y DISPUTAS
// ============================================================

model Incident {
  id               String           @id @default(uuid()) @db.Uuid
  incidentNumber   String           @unique @map("incident_number")
  customerId       String           @map("customer_id") @db.Uuid
  storeId          String           @map("store_id") @db.Uuid
  subOrderId       String?          @map("sub_order_id") @db.Uuid
  type             IncidentType
  status           IncidentStatus   @default(OPEN)
  priority         IncidentPriority @default(MEDIUM)
  subject          String
  description      String           @db.Text
  customerEvidence Json?            @map("customer_evidence") // URLs de fotos/capturas
  sellerEvidence   Json?            @map("seller_evidence")
  resolution       String?          @db.Text
  resolvedBy       String?          @map("resolved_by") @db.Uuid // userId del admin o auto
  sellerFirstResponseAt DateTime?   @map("seller_first_response_at")
  escalatedAt      DateTime?        @map("escalated_at")
  resolvedAt       DateTime?        @map("resolved_at")
  closedAt         DateTime?        @map("closed_at")
  deadlineAt       DateTime?        @map("deadline_at") // Fecha límite para responder
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relaciones
  customer User              @relation("incidentCustomer", fields: [customerId], references: [id])
  store    Store             @relation(fields: [storeId], references: [id])
  messages IncidentMessage[]

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([deadlineAt])
  @@map("incidents")
}

model IncidentMessage {
  id          String   @id @default(uuid()) @db.Uuid
  incidentId  String   @map("incident_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  senderRole  UserRole @map("sender_role") // CUSTOMER, SELLER, or ADMIN
  body        String   @db.Text
  attachments Json?    // URLs de archivos adjuntos
  isInternal  Boolean  @default(false) @map("is_internal") // Notas internas admin
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sender   User     @relation("incidentMessageSender", fields: [senderId], references: [id])

  @@index([incidentId])
  @@index([senderId])
  @@map("incident_messages")
}

// ============================================================
// PENALIZACIONES Y SALUD DE TIENDA
// ============================================================

model StorePenalty {
  id            String       @id @default(uuid()) @db.Uuid
  storeId       String       @map("store_id") @db.Uuid
  incidentId    String?      @map("incident_id") @db.Uuid
  type          PenaltyType
  status        PenaltyStatus @default(ACTIVE)
  reason        String       @db.Text
  details       Json?        // Detalles específicos (% comisión extra, días suspensión, etc.)
  points        Int          @default(0) // Puntos de penalización acumulados
  issuedBy      String?      @map("issued_by") @db.Uuid // Admin que impuso, null = automático
  appealReason  String?      @map("appeal_reason") @db.Text
  appealedAt    DateTime?    @map("appealed_at")
  expiresAt     DateTime?    @map("expires_at")
  revokedAt     DateTime?    @map("revoked_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  // Relaciones
  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([status])
  @@index([expiresAt])
  @@map("store_penalties")
}

model StoreHealthScore {
  id                    String   @id @default(uuid()) @db.Uuid
  storeId               String   @unique @map("store_id") @db.Uuid
  overallScore          Int      @default(100) @map("overall_score") // 0-100
  responseRate          Decimal  @default(100) @map("response_rate") @db.Decimal(5, 2) // % mensajes respondidos
  avgResponseTimeHours  Decimal  @default(0) @map("avg_response_time_hours") @db.Decimal(8, 2)
  onTimeShippingRate    Decimal  @default(100) @map("on_time_shipping_rate") @db.Decimal(5, 2)
  incidentRate          Decimal  @default(0) @map("incident_rate") @db.Decimal(5, 2) // incidencias / pedidos
  resolutionRate        Decimal  @default(100) @map("resolution_rate") @db.Decimal(5, 2) // % incidencias resueltas
  cancelationRate       Decimal  @default(0) @map("cancelation_rate") @db.Decimal(5, 2)
  totalPenaltyPoints    Int      @default(0) @map("total_penalty_points")
  activePenalties       Int      @default(0) @map("active_penalties")
  lastEvaluatedAt       DateTime @default(now()) @map("last_evaluated_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relaciones
  store Store @relation(fields: [storeId], references: [id])

  @@map("store_health_scores")
}
